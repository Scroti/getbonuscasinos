# Firebase Configuration
# Get these values from Firebase Console > Project Settings > General > Your apps
# Copy this file to .env.local and fill in your actual values

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Optional: override canonical base only if Host headers are missing (odd proxies, scripts).
# Live requests normally use Host / X-Forwarded-* from lib/site-url.ts — no var needed.
# NEXT_PUBLIC_CANONICAL_URL=https://getbonuscasinos.com

# Site title & logo (optional)
# NEXT_PUBLIC_SITE_TITLE=Get Bonus Casinos
# NEXT_PUBLIC_LOGO_LINE1=getbonus
# NEXT_PUBLIC_LOGO_LINE2=CASINOS
#
# Multi-domain on one build:
# NEXT_PUBLIC_SITE_BRANDS_JSON={"reelslots.org":{"title":"ReelSlots","logoLine1":"reelslots","logoLine2":""}}
#
# Defaults: built-in map in lib/site-brand.ts + heuristic from hostname when unknown.


